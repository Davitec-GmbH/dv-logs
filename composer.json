{
	"name": "davitec/dv-logs",
	"description": "Lightweight TYPO3 backend module that provides a simple interface for viewing and managing TYPO3 system log files",
	"license": [
		"GPL-2.0-or-later"
	],
	"type": "typo3-cms-extension",
	"authors": [
		{
			"name": "Davitec GmbH, +Pluswerk Standort Dresden",
			"email": "devops@davitec.de"
		}
	],
	"homepage": "https://github.com/Davitec-GmbH/dv-logs",
	"support": {
		"source": "https://github.com/Davitec-GmbH/dv-logs"
	},
	"require": {
		"typo3/cms-core": "^12 || ^13.0 || ^14.0"
	},
	"autoload": {
		"psr-4": {
			"Davitec\\Dvlogs\\": "Classes/"
		}
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "dv_logs"
		}
	}
}
