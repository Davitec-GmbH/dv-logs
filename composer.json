{
	"name": "davitec/dv-logs",
	"type": "typo3-cms-extension",
	"description": "Lightweight TYPO3 backend module that provides a simple interface for viewing and managing TYPO3 system log files",
	"homepage": "https://www.davitec.de/",
	"authors": [
		{
			"name": "Philipp Gollmer",
			"email": "pg@davitec.de",
			"homepage": "https://www.davitec.de/",
			"role": "Project Owner"
		},
		{
			"name": "Rao Faraz Shakeel",
			"homepage": "https://www.davitec.de/",
			"role": "Developer"
		}
	],
	"license": [
		"GPL-2.0-or-later"
	],
	"version": "1.0.0",
	"require": {
		"typo3/cms-core": "^13.4"
	},
	"autoload": {
		"psr-4": {
			"Davitec\\Dvlogs\\": "Classes/"
		}
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "dv_logs"
		}
	}
}
